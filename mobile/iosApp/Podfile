# iosApp/Podfile
platform :ios, '15.0'

target 'iosApp' do
  use_frameworks!
  pod 'composeApp', :path => '../composeApp'
  pod 'MijickCamera', '~> 3.0.0'

  post_install do |installer|
    installer.pods_project.targets.each do |target|
      target.build_configurations.each do |config|
        config.build_settings['OTHER_LDFLAGS'] ||= ['$(inherited)']
        flags = config.build_settings['OTHER_LDFLAGS']
        flags = [flags] unless flags.is_a?(Array)
        flags << '-lsqlite3' unless flags.include?('-lsqlite3')
        config.build_settings['OTHER_LDFLAGS'] = flags

        # Disable Swift 6 strict concurrency via compiler flag (overrides xcconfig)
        config.build_settings['SWIFT_STRICT_CONCURRENCY'] = 'minimal'
        other_swift_flags = config.build_settings['OTHER_SWIFT_FLAGS'] || '$(inherited)'
        unless other_swift_flags.include?('-strict-concurrency=minimal')
          config.build_settings['OTHER_SWIFT_FLAGS'] = "#{other_swift_flags} -strict-concurrency=minimal"
        end
        config.build_settings['SWIFT_VERSION'] = '5.9' if target.name.start_with?('Mijick')
      end
    end

    # Patch MijickCamera: add @MainActor to protocol extensions that call @MainActor CameraManager
    mijick_screen = File.join(installer.sandbox.root, 'MijickCamera/Sources/Public/UI/Public+UI+MCameraScreen.swift')
    if File.exist?(mijick_screen)
      content = File.read(mijick_screen)
      patched = content.gsub(/^public extension MCameraScreen \{/, '@MainActor public extension MCameraScreen {')
      File.write(mijick_screen, patched) if content != patched
    end

    installer.aggregate_targets.each do |aggregate_target|
      aggregate_target.user_project.native_targets.each do |native_target|
        native_target.build_configurations.each do |config|
          existing = config.build_settings['OTHER_LDFLAGS'] || '$(inherited)'
          value = existing.is_a?(Array) ? existing.join(' ') : existing.to_s
          config.build_settings['OTHER_LDFLAGS'] = "#{value} -lsqlite3" unless value.include?('-lsqlite3')
        end
      end
      aggregate_target.user_project.save
    end
  end
end
